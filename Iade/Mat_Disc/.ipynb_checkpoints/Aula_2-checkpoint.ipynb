   "outputs": [],
   "source": [
    "def MidPoint(f, x0, xf, n):\n",
    "    dx = (xf-x0)/n\n",
    "\n",
    "    soma=0\n",
    "    x=x0+dx/2\n",
    "    i=0\n",
    "    while i<n:\n",
    "        soma+=dx*f(x)\n",
    "        x+=dx\n",
    "        i+=1\n",
    "    return soma"
   ]
  },
  {
